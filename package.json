{
  "name": "rick-and-morty-explorer",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dataset:prepare -- --if-missing && vite",
    "build": "tsc -b && vite build && cp -v dist/index.html dist/404.html",
    "assets:backgrounds": "node scripts/render-background-assets.mjs",
    "dataset:prepare": "node scripts/prepare-kaggle-dataset.mjs",
    "dataset:kaggle": "npm run dataset:prepare",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:screenshots": "playwright test src/screenshot.test.ts"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vitest-browser-react": "^2.2.0"
  }
}
